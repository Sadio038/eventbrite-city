<div class="row justify-content-center">
  <div class="col-md-8">
    <h2 class="mb-4">Modifier mon profil</h2>

    <%= form_with model: @user, multipart: true do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :first_name, "Prénom", class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, "Nom", class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :description, "Description", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4 %>
      </div>

      <div class="mb-3">
        <%= f.label :avatar, "Photo de profil", class: "form-label" %>
        <%= f.file_field :avatar, class: "form-control", accept: "image/*" %>
        <% if @user.avatar.attached? %>
          <div class="mt-2">
            <small class="text-muted">Photo actuelle :</small><br>
            <%= image_tag @user.avatar, class: "rounded-circle mt-1", style: "width: 80px; height: 80px; object-fit: cover;" %>
          </div>
        <% end %>
      </div>

      <div class="d-grid">
        <%= f.submit "Mettre à jour", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>
