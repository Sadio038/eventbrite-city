<div class="bg-light border-bottom py-3 mb-4">
  <div class="container">
    <h2 class="fw-bold mb-0">👤 Mon profil</h2>
    <p class="text-muted mt-1">Gérez vos informations personnelles</p>
  </div>
</div>

<div class="container mb-5">
  <div class="row g-4">
    <div class="col-md-4">
      <%= render 'users/profile_card' %>
    </div>

    <div class="col-md-8">
      <h4 class="fw-bold mb-3">🎪 Mes événements créés</h4>
      <% if @user.events.empty? %>
        <div class="text-center py-4 bg-light rounded">
          <p class="text-muted mb-2">Tu n'as pas encore créé d'événement.</p>
          <a href="<%= new_event_path %>" class="btn btn-primary btn-sm">Créer un événement</a>
        </div>
      <% else %>
        <div class="list-group">
          <% @user.events.each do |event| %>
            <a href="<%= event_path(event) %>" class="list-group-item list-group-item-action">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <h6 class="mb-1 fw-bold"><%= event.title %></h6>
                  <small class="text-muted">📍 <%= event.location %> —
                    💰 <%= event.is_free? ? "Gratuit" : "#{event.price} €" %>
                  </small>
                </div>
                <div class="text-end">
                  <small class="text-muted"><%= event.start_date.strftime("%d/%m/%Y") %></small>
                  <br>
                  <% if event.approved? %>
                    <span class="badge bg-success">✅ Validé</span>
                  <% elsif event.rejected? %>
                    <span class="badge bg-danger">❌ Refusé</span>
                  <% else %>
                    <span class="badge bg-warning">⏳ En attente</span>
                  <% end %>
                </div>
              </div>
            </a>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>