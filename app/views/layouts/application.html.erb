<!DOCTYPE html>
<html>
  <head>
    <title>EventBrite City</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">EventBrite City</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/">Accueil</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="<%= new_event_path %>">Créer un événement</a>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                  Mon profil
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
  		<li><a class="dropdown-item" href="<%= user_path(current_user) %>">Mon profil</a></li>
	  	<li><%= button_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "dropdown-item btn btn-link" %></li>
		</ul>
		
              </li>
            <% else %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                  S'inscrire / Se connecter
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
  		  <li><a class="dropdown-item" href="<%= new_user_registration_path %>">S'inscrire</a></li>
		  <li><a class="dropdown-item" href="<%= new_user_session_path %>">Se connecter</a></li>
		</ul>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- CONTENU -->
    <div class="container mt-4">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
