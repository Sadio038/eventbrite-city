<h2>🎉 Gestion des événements</h2>
<hr>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Titre</th>
      <th>Créateur</th>
      <th>Date</th>
      <th>Prix</th>
      <th>Statut</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr>
        <td><%= event.title %></td>
        <td><%= event.user.email %></td>
        <td><%= event.start_date.strftime("%d/%m/%Y") %></td>
        <td><%= event.is_free? ? "Gratuit" : "#{event.price} €" %></td>
        <td>
          <% if event.approved? %>
            <span class="badge bg-success">✅ Validé</span>
          <% elsif event.rejected? %>
            <span class="badge bg-danger">❌ Refusé</span>
          <% else %>
            <span class="badge bg-warning">⏳ En attente</span>
          <% end %>
        </td>
        <td>
          <a href="<%= edit_admin_event_path(event) %>" class="btn btn-outline-primary btn-sm">Modifier</a>
          <%= button_to "Supprimer", admin_event_path(event), method: :delete,
              class: "btn btn-danger btn-sm",
              form: { data: { turbo_confirm: "Supprimer cet événement ?" } } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
