<h2>👥 Gestion des utilisateurs</h2>
<hr>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Email</th>
      <th>Prénom</th>
      <th>Nom</th>
      <th>Admin ?</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.first_name %></td>
        <td><%= user.last_name %></td>
        <td><%= user.is_admin? ? "✅ Oui" : "❌ Non" %></td>
        <td>
          <a href="<%= edit_admin_user_path(user) %>" class="btn btn-outline-primary btn-sm">Modifier</a>
          <%= button_to "Supprimer", admin_user_path(user), method: :delete,
              class: "btn btn-danger btn-sm",
              form: { data: { turbo_confirm: "Supprimer cet utilisateur ?" } } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
