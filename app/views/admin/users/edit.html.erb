<h2>✏️ Modifier l'utilisateur</h2>
<hr>

<div class="row justify-content-center">
  <div class="col-md-6">
    <%= form_with model: [:admin, @user] do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :first_name, "Prénom", class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.label :last_name, "Nom", class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control" %>
      </div>
      <div class="mb-3 form-check">
        <%= f.check_box :is_admin, class: "form-check-input" %>
        <%= f.label :is_admin, "Administrateur", class: "form-check-label" %>
      </div>
      <div class="d-grid">
        <%= f.submit "Mettre à jour", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
