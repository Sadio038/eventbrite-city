<div class="row">
  <div class="col-md-8">
    <h2><%= @event.title %></h2>
    <p class="text-muted">Créé par <%= @event.user.email %></p>
    <hr>
    <p><%= @event.description %></p>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <ul class="list-unstyled">
          <li>📅 <%= @event.start_date.strftime("%d/%m/%Y à %Hh%M") %></li>
          <li>⏱ <%= @event.duration %> minutes</li>
          <li>📍 <%= @event.location %></li>
          <li>💰 <%= @event.is_free? ? "Gratuit" : "#{@event.price} €" %></li>
        </ul>
        <hr>
        <%= form_with url: admin_event_submission_path(@event), method: :patch do |f| %>
          <%= f.submit "✅ Valider", name: "approved", class: "btn btn-success d-block mb-2" %>
          <%= f.submit "❌ Refuser", name: "rejected", class: "btn btn-danger d-block" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
