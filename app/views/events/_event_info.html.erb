<div class="card shadow-sm h-100">
  <div class="card-body d-flex flex-column justify-content-between">
    <div>
      <h3 class="fw-bold"><%= @event.title %></h3>
      <p class="text-muted small">Créé par <%= @event.user.email %></p>
      <hr>
      <ul class="list-unstyled">
        <li class="mb-2">📅 <strong>Début :</strong> <%= @event.start_date.strftime("%d/%m/%Y à %Hh%M") %></li>
        <li class="mb-2">⏱ <strong>Durée :</strong> <%= @event.duration %> minutes</li>
        <li class="mb-2">📍 <strong>Lieu :</strong> <%= @event.location %></li>
        <li class="mb-2">💰 <strong>Prix :</strong> <%= @event.is_free? ? "Gratuit" : "#{@event.price} €" %></li>
        <li class="mb-2">👥 <strong>Participants :</strong> <%= @event.attendances.count %></li>
      </ul>
    </div>
    <div>
      <% if user_signed_in? %>
        <% if current_user == @event.user %>
          <a href="<%= event_attendances_path(@event) %>" class="btn btn-outline-secondary d-block mb-2">
            👥 Mon espace événement
          </a>
        <% elsif @event.attendances.exists?(user: current_user) %>
          <div class="alert alert-success text-center mb-0">✅ Vous participez à cet événement</div>
        <% else %>
          <% if @event.is_free? %>
            <a href="<%= new_event_attendance_path(@event) %>" class="btn btn-success btn-lg d-block">
              🎉 Rejoindre gratuitement
            </a>
          <% else %>
            <a href="<%= new_event_attendance_path(@event) %>" class="btn btn-primary btn-lg d-block">
              Rejoindre — <%= @event.price %> €
            </a>
          <% end %>
        <% end %>
      <% else %>
        <a href="<%= new_user_session_path %>" class="btn btn-outline-primary d-block">
          Connectez-vous pour rejoindre
        </a>
      <% end %>
    </div>
  </div>
</div>