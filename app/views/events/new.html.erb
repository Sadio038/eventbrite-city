<div class="row justify-content-center">
  <div class="col-md-8">
    <h2 class="mb-4">Créer un événement</h2>

    <%= form_with model: @event do |f| %>
      <% if @event.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @event.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :title, "Titre", class: "form-label" %>
        <%= f.text_field :title, class: "form-control", placeholder: "Titre de l'événement" %>
      </div>

      <div class="mb-3">
        <%= f.label :description, "Description", class: "form-label" %>
        <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Décrivez votre événement..." %>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :start_date, "Date de début", class: "form-label" %>
          <%= f.datetime_local_field :start_date, class: "form-control" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label :duration, "Durée (en minutes)", class: "form-label" %>
          <%= f.number_field :duration, class: "form-control", placeholder: "Ex: 60" %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :price, "Prix (en euros)", class: "form-label" %>
          <%= f.number_field :price, class: "form-control", placeholder: "Ex: 10" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label :location, "Lieu", class: "form-label" %>
          <%= f.text_field :location, class: "form-control", placeholder: "Ex: Dakar, Plateau" %>
        </div>
      </div>

      <div class="d-grid">
        <%= f.submit "Créer l'événement", class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>
