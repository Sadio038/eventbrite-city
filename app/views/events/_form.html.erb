<%= form_with model: @event, multipart: true do |f| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Titre", class: "form-label fw-bold" %>
    <%= f.text_field :title, class: "form-control", placeholder: "Titre de l'événement" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Description", class: "form-label fw-bold" %>
    <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Décrivez votre événement..." %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :start_date, "Date de début", class: "form-label fw-bold" %>
      <%= f.datetime_local_field :start_date, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :duration, "Durée (minutes)", class: "form-label fw-bold" %>
      <%= f.number_field :duration, class: "form-control", placeholder: "Ex: 60" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :price, "Prix (euros)", class: "form-label fw-bold" %>
      <%= f.number_field :price, class: "form-control", placeholder: "0 pour gratuit" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :location, "Lieu", class: "form-label fw-bold" %>
      <%= f.text_field :location, class: "form-control", placeholder: "Ex: Dakar, Plateau" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :cover, "Photo de couverture", class: "form-label fw-bold" %>
    <%= f.file_field :cover, class: "form-control", accept: "image/*" %>
    <% if @event.persisted? && @event.cover.attached? %>
      <div class="mt-2">
        <small class="text-muted">Photo actuelle :</small><br>
        <%= image_tag @event.cover, class: "mt-1 rounded", style: "width: 200px; object-fit: cover;" %>
      </div>
    <% end %>
  </div>

  <div class="d-grid">
    <%= f.submit class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
