<div class="row">
  <div class="col-md-8">
    <h1><%= @event.title %></h1>
    <% if @event.cover.attached? %>
      <%= image_tag @event.cover, class: "img-fluid rounded mb-3", style: "max-height: 400px; width: 100%; object-fit: cover;" %>
    <% end %>
    <p class="text-muted">Créé par <%= @event.user.email %></p>
    <hr>
    <p><%= @event.description %></p>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <ul class="list-unstyled">
          <li class="mb-2">📅 <strong>Début :</strong> <%= @event.start_date.strftime("%d/%m/%Y à %Hh%M") %></li>
          <li class="mb-2">⏱ <strong>Durée :</strong> <%= @event.duration %> minutes</li>
          <li class="mb-2">📍 <strong>Lieu :</strong> <%= @event.location %></li>
          <li class="mb-2">💰 <strong>Prix :</strong> <%= @event.price %> €</li>
          <li class="mb-2">👥 <strong>Participants :</strong> <%= @event.attendances.count %></li>
        </ul>
        <hr>

        <% if user_signed_in? %>
          <% if current_user == @event.user %>
            <!-- Le créateur voit le lien vers la liste des invités -->
            <a href="<%= event_attendances_path(@event) %>" class="btn btn-outline-secondary btn-sm d-block mb-2">
              👥 Mon espace événement
            </a>
        <% else %>
          <!-- Peut rejoindre -->
          <% if @event.is_free? %>
          <a href="<%= new_event_attendance_path(@event) %>" class="btn btn-success btn-lg d-block">
            🎉 Rejoindre gratuitement
          </a>
        <% else %>
          <a href="<%= new_event_attendance_path(@event) %>" class="btn btn-primary btn-lg d-block">
            Rejoindre l'événement — <%= @event.price %> €
          </a>
          <% end %>
        <% end %>
        <% else %>
          <a href="<%= new_user_session_path %>" class="btn btn-outline-primary d-block">
            Connectez-vous pour rejoindre
          </a>
        <% end %>
      </div>
    </div>
  </div>
</div>
