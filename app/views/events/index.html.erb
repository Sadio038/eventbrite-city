<!-- Bannière principale -->
<div class="bg-primary text-white py-5 mb-5">
  <div class="container text-center">
    <h1 class="display-4 fw-bold">Découvrez les meilleurs événements de Dakar 🎉</h1>
    <p class="lead">Concerts, sports, conférences, ateliers... Trouvez l'événement qui vous correspond !</p>
    <% if user_signed_in? %>
      <a href="<%= new_event_path %>" class="btn btn-light btn-lg fw-bold">Créer un événement</a>
    <% else %>
      <a href="<%= new_user_registration_path %>" class="btn btn-light btn-lg fw-bold">Rejoindre EventFreeka</a>
    <% end %>
  </div>
</div>

<!-- Liste des événements -->
<div class="container mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">🎪 Événements à Dakar</h3>
    <span class="badge bg-primary fs-6"><%= @events.count %> événements</span>
  </div>

  <% if @events.empty? %>
    <div class="text-center py-5">
      <p class="display-1">🎪</p>
      <h4 class="text-muted">Aucun événement disponible pour le moment</h4>
      <% if user_signed_in? %>
        <a href="<%= new_event_path %>" class="btn btn-primary mt-3">Créer le premier événement</a>
      <% end %>
    </div>
  <% else %>
    <div class="row">
      <% @events.each do |event| %>
        <%= render 'events/event_card', event: event %>
      <% end %>
    </div>
  <% end %>
</div>
